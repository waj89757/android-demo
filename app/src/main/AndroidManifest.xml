<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ★ 网络请求权限 —— 不加这个，所有 HTTP 请求都会失败 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ★ 网络状态查询权限（读取 WiFi/移动数据连接状态）-->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- ★ Foreground Service 权限（Android 9.0+ 必须声明）-->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- ★ Foreground Service 类型权限（Android 14+ 必须声明具体类型）-->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    
    <!-- ★ 通知权限（Android 13+ 必须声明）-->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- ★ 读取手机联系人（运行时权限，用户需主动授权）-->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Demo01"
        tools:targetApi="31">

        <activity
            android:name=".SecondActivity"
            android:exported="false" />
        <activity
            android:name=".FragmentDemoActivity"
            android:exported="false" />
        <activity
            android:name=".ViewPagerDemoActivity"
            android:exported="false" />
        <activity
            android:name=".NetworkDemoActivity"
            android:exported="false" />
        <activity
            android:name=".ViewModelDemoActivity"
            android:exported="false" />
        <activity
            android:name=".LiveDataCompareActivity"
            android:exported="false" />
        <activity
            android:name=".MvpDemoActivity"
            android:exported="false" />

        <!--
        ★★★ DeepLink 核心配置 ★★★

        android:exported="true" 必须设为 true，
        因为这个 Activity 要接收来自系统/外部的 Intent。
        exported=false 的 Activity 只能被同一个 App 内部启动。

        intent-filter 告诉 Android 系统：
          "当有人想用 VIEW 动作打开 demo01://post 这个 URL 时，
           请启动我（DeepLinkDemoActivity）"

        Android 在 App 安装时扫描所有 intent-filter，
        建立一张"URL pattern → Activity"的路由表，
        之后收到匹配的 URL 就来找这里。
        -->
        <activity
            android:name=".DeepLinkDemoActivity"
            android:exported="true">

            <intent-filter>
                <!-- ACTION_VIEW：表示"查看/打开某个内容"，DeepLink 固定用这个 -->
                <action android:name="android.intent.action.VIEW" />

                <!-- DEFAULT：允许通过隐式 Intent 匹配 -->
                <category android:name="android.intent.category.DEFAULT" />

                <!-- BROWSABLE：允许从浏览器点链接触发（不加这个，浏览器里点链接不会触发）-->
                <category android:name="android.intent.category.BROWSABLE" />

                <!--
                ★ 声明这个 Activity 处理哪种 URL 格式：
                   scheme="demo01" + host="post"
                   → 匹配 demo01://post 和 demo01://post?任意参数

                   完整例子：demo01://post?id=123&title=HelloWorld
                -->
                <data
                    android:scheme="demo01"
                    android:host="post" />
            </intent-filter>
        </activity>
        <activity
            android:name=".AmsDemoActivity"
            android:exported="false" />
        
        <!-- ★★★ Service 注册 ★★★ -->
        <service
            android:name=".MockPushService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        
        <activity
            android:name=".ServiceDemoActivity"
            android:exported="false" />
        
        <activity
            android:name=".HandlerDemoActivity"
            android:exported="false" />

        <activity
            android:name=".SurfaceDemoActivity"
            android:exported="false" />

        <activity
            android:name=".BroadcastDemoActivity"
            android:exported="false" />

        <activity
            android:name=".ContentProviderDemoActivity"
            android:exported="false" />

        <activity
            android:name=".WebViewDemoActivity"
            android:exported="false" />

        <activity
            android:name=".OfflineDemoActivity"
            android:exported="false" />

        <activity
            android:name=".HotUpdateDemoActivity"
            android:exported="false" />

        <!--
            ★★★ RN 容器 Activity：支持两种启动方式
            1. Native 内部：startActivity + putExtra("uri", "myapp://...")
            2. DeepLink：浏览器/Push 打开 myapp:// URI，系统自动路由到此 Activity
        -->
        <!-- ★ 用户个人资料页（Figma UI 练习） -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- ★ Wanas 首页（Fragment + BottomNav + RecyclerView 多类型练习） -->
        <activity
            android:name=".WanasActivity"
            android:exported="false" />

        <!-- ★ DiffUtil / ListAdapter 演示（商品列表增删改动画） -->
        <activity
            android:name=".DiffUtilDemoActivity"
            android:exported="false" />

        <!-- ★★★ KRN 演示：真实 React Native 页面 ★★★ -->
        <activity
            android:name=".KRNActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".RNContainerActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- ★ 注册 URI scheme：myapp:// -->
                <data android:scheme="myapp" />
            </intent-filter>
        </activity>

        <!--
        ★★★ ContentProvider 注册 ★★★
        authorities：全局唯一标识，相当于域名，调用方通过它找到这个 Provider
        exported：false = 仅 App 内部使用，true = 对外开放（需要配合 permission）
        -->
        <provider
            android:name=".NoteContentProvider"
            android:authorities="com.example.demo01.notes"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>