<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ★ 网络请求权限 —— 不加这个，所有 HTTP 请求都会失败 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ★ 网络状态查询权限（读取 WiFi/移动数据连接状态）-->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- ★ Foreground Service 权限（Android 9.0+ 必须声明）-->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- ★ Foreground Service 类型权限（Android 14+ 必须声明具体类型）-->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    
    <!-- ★ 通知权限（Android 13+ 必须声明）-->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- ★ 读取手机联系人（运行时权限，用户需主动授权）-->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Demo01"
        tools:targetApi="31">

        <!-- ══════════════════════════════════════════════════
             feature-demo 模块的组件（包名 com.example.demo）
             重构后从 com.example.demo01 迁移到此模块
        ══════════════════════════════════════════════════ -->

        <activity
            android:name="com.example.demo.SecondActivity"
            android:exported="false" />
        <activity
            android:name="com.example.demo.FragmentDemoActivity"
            android:exported="false" />
        <activity
            android:name="com.example.demo.ViewPagerDemoActivity"
            android:exported="false" />
        <activity
            android:name="com.example.demo.NetworkDemoActivity"
            android:exported="false" />
        <activity
            android:name="com.example.demo.ViewModelDemoActivity"
            android:exported="false" />
        <activity
            android:name="com.example.demo.LiveDataCompareActivity"
            android:exported="false" />
        <activity
            android:name="com.example.demo.MvpDemoActivity"
            android:exported="false" />

        <!--
        ★★★ DeepLink 核心配置 ★★★
        android:exported="true" 必须设为 true，
        因为这个 Activity 要接收来自系统/外部的 Intent。
        -->
        <activity
            android:name="com.example.demo.DeepLinkDemoActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="demo01"
                    android:host="post" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.demo.AmsDemoActivity"
            android:exported="false" />
        
        <!-- ★★★ Service 注册 ★★★ -->
        <service
            android:name="com.example.demo.MockPushService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        
        <activity
            android:name="com.example.demo.ServiceDemoActivity"
            android:exported="false" />
        
        <activity
            android:name="com.example.demo.HandlerDemoActivity"
            android:exported="false" />

        <activity
            android:name="com.example.demo.SurfaceDemoActivity"
            android:exported="false" />

        <activity
            android:name="com.example.demo.BroadcastDemoActivity"
            android:exported="false" />

        <activity
            android:name="com.example.demo.ContentProviderDemoActivity"
            android:exported="false" />

        <activity
            android:name="com.example.demo.WebViewDemoActivity"
            android:exported="false" />

        <activity
            android:name="com.example.demo.ProfileActivity"
            android:exported="false" />

        <!-- ★ Wanas 首页（Fragment + BottomNav + RecyclerView 多类型练习） -->
        <activity
            android:name="com.example.demo.WanasActivity"
            android:exported="false" />

        <!-- ★ DiffUtil / ListAdapter 演示（商品列表增删改动画） -->
        <activity
            android:name="com.example.demo.DiffUtilDemoActivity"
            android:exported="false" />

        <!--
        ★★★ ContentProvider 注册 ★★★
        authorities：全局唯一标识，相当于域名，调用方通过它找到这个 Provider
        exported：false = 仅 App 内部使用
        -->
        <provider
            android:name="com.example.demo.NoteContentProvider"
            android:authorities="com.example.demo01.notes"
            android:exported="false" />

        <!-- ══════════════════════════════════════════════════
             feature-krn 模块的组件（包名 com.example.krn）
        ══════════════════════════════════════════════════ -->

        <activity
            android:name="com.example.krn.OfflineDemoActivity"
            android:exported="false" />

        <activity
            android:name="com.example.krn.HotUpdateDemoActivity"
            android:exported="false" />

        <!-- ★★★ KRN 演示：真实 React Native 页面 ★★★ -->
        <activity
            android:name="com.example.krn.KRNActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!--
            ★★★ RN 容器 Activity：支持两种启动方式
            1. Native 内部：startActivity + putExtra("uri", "myapp://...")
            2. DeepLink：浏览器/Push 打开 myapp:// URI，系统自动路由到此 Activity
        -->
        <activity
            android:name="com.example.krn.RNContainerActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- ★ 注册 URI scheme：myapp:// -->
                <data android:scheme="myapp" />
            </intent-filter>
        </activity>

        <!-- ══════════════════════════════════════════════════
             app 模块自身的组件（包名 com.example.demo01）
        ══════════════════════════════════════════════════ -->

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
