<?xml version="1.0" encoding="utf-8"?>
<!-- ★ 加了 ScrollView，内容超出屏幕时可以往下滚动看到所有按钮 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 页面主标题 -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="后端安卓客户端练习"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_gravity="center"/>

        <!-- 文字输入框 -->
        <EditText
            android:id="@+id/et_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="请输入任意内容"
            android:textSize="16sp"
            android:inputType="text"
            android:background="@drawable/edit_bg"
            android:paddingHorizontal="15dp"
            android:layout_marginTop="30dp"/>

        <!-- 按钮区：展示 + 清空 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btn_show"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="展示输入内容"/>

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="清空输入"/>
        </LinearLayout>

        <!-- 页面跳转按钮 -->
        <Button
            android:id="@+id/btn_jump"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="跳转到第二个页面并传值"
            android:layout_marginTop="15dp"/>

        <!-- Bundle 传值按钮 -->
        <Button
            android:id="@+id/btn_bundle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="用 Bundle 传多个值跳转"
            android:layout_marginTop="15dp"/>

        <!-- 确认对话框按钮 -->
        <Button
            android:id="@+id/btn_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="弹出确认对话框"
            android:layout_marginTop="15dp"/>

        <!-- ★ Fragment 演示按钮 -->
        <Button
            android:id="@+id/btn_fragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="进入 Fragment 演示页面"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="15dp"/>

        <!-- ★ ViewPager2 演示按钮 -->
        <Button
            android:id="@+id/btn_viewpager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ViewPager2 滑动切换页面"
            android:backgroundTint="#1565C0"
            android:layout_marginTop="15dp"/>

        <!-- ★ 网络请求演示按钮 -->
        <Button
            android:id="@+id/btn_network"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="网络请求（调用后端 API）"
            android:backgroundTint="#FF6F00"
            android:layout_marginTop="15dp"/>

        <!-- 列表控件 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_list"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="15dp"/>

    </LinearLayout>

</ScrollView>