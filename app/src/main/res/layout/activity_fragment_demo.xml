<?xml version="1.0" encoding="utf-8"?>
<!-- FragmentDemoActivity 的布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="15dp"
    android:background="#F8F9FA">

    <!-- 顶部标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fragment 学习演示"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"/>

    <!-- 切换按钮区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="15dp">

        <Button
            android:id="@+id/btn_tab_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="首页"/>

        <Button
            android:id="@+id/btn_tab_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="个人主页"/>

        <!-- ★ 返回主页按钮 -->
        <Button
            android:id="@+id/btn_back_main"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="返回主页"
            android:backgroundTint="#F44336"/>

    </LinearLayout>

    <!-- ★ FragmentContainerView —— Fragment 的宿主容器 -->
    <!-- FragmentManager 会把 Fragment 的布局填充到这个容器里 -->
    <!-- 这是现代 Android 推荐的方式，替代了旧的 FrameLayout -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="15dp"/>

</LinearLayout>