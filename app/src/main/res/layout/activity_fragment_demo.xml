<?xml version="1.0" encoding="utf-8"?>
<!-- FragmentDemoActivity 布局：支持 Replace/ShowHide 双模式 + 生命周期 Tab -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="15dp"
    android:background="#F8F9FA">

    <!-- 顶部标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fragment 学习演示"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"/>

    <!-- ★ 模式切换区：Replace模式 vs Show/Hide模式 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="切换模式："
            android:textSize="16sp"
            android:textColor="#555555"/>

        <Button
            android:id="@+id/btn_mode_replace"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Replace模式"
            android:textSize="14sp"
            android:backgroundTint="#F44336"/>

        <Button
            android:id="@+id/btn_mode_show_hide"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Show/Hide模式"
            android:textSize="14sp"
            android:backgroundTint="#4CAF50"/>

        <!-- 当前模式提示 -->
        <TextView
            android:id="@+id/tv_current_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前：Replace"
            android:textSize="14sp"
            android:textColor="#F44336"
            android:textStyle="bold"
            android:layout_marginStart="10dp"/>

    </LinearLayout>

    <!-- Tab 按钮区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/btn_tab_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="首页"/>

        <Button
            android:id="@+id/btn_tab_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="个人主页"/>

        <Button
            android:id="@+id/btn_tab_lifecycle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="★生命周期"
            android:backgroundTint="#1565C0"/>

        <Button
            android:id="@+id/btn_back_main"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="返回主页"
            android:backgroundTint="#F44336"/>

    </LinearLayout>

    <!-- ★ FragmentContainerView —— Fragment 的宿主容器 -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"/>

</LinearLayout>